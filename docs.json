{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Marky API",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "topbarCtaButton": {
    "name": "Dashboard",
    "url": "https://app.mymarky.ai"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "authentication", "quickstart"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Posts",
            "pages": [
              "api-reference/generate-posts",
              "api-reference/get-job-status",
              "api-reference/list-posts",
              "api-reference/get-post"
            ]
          }
        ]
      }
    ]
  },
  "openapi": "https://api.mymarky.ai/api/beta/openapi.json",
  "api": {
    "baseUrl": "https://api.mymarky.ai",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    }
  },
  "footerSocials": {
    "website": "https://mymarky.ai"
  }
}
