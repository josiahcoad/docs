{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Marky API",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "topbarCtaButton": {
    "name": "Dashboard",
    "url": "https://app.mymarky.ai"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "authentication", "quickstart", "terms"]
          },
          {
            "group": "Integrations",
            "pages": [
              "guides/ai-agents",
              "guides/zapier-make",
              "guides/go-high-level"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Posts",
            "pages": [
              "api-reference/create-post",
              "api-reference/list-posts",
              "api-reference/get-post",
              "api-reference/update-post",
              "api-reference/schedule-post"
            ]
          },
          {
            "group": "Businesses",
            "pages": [
              "api-reference/create-business",
              "api-reference/list-businesses",
              "api-reference/get-business",
              "api-reference/update-business",
              "api-reference/delete-business"
            ]
          },
          {
            "group": "Topics",
            "pages": [
              "api-reference/create-topic",
              "api-reference/list-topics",
              "api-reference/get-topic",
              "api-reference/update-topic",
              "api-reference/delete-topic"
            ]
          },
          {
            "group": "Library",
            "pages": [
              "api-reference/list-library",
              "api-reference/get-library-file",
              "api-reference/delete-library-file"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/create-webhook",
              "api-reference/list-webhooks",
              "api-reference/delete-webhook",
              "api-reference/list-webhook-deliveries"
            ]
          }
        ]
      }
    ]
  },
  "openapi": "https://api.mymarky.ai/api/beta/openapi.json",
  "api": {
    "baseUrl": "https://api.mymarky.ai",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    }
  },
  "footerSocials": {
    "website": "https://mymarky.ai"
  }
